{
  "mcpServers": {
    "polish-history": {
      "type": "stdio",
      "command": "/home/macryba/mcp-server/.venv/bin/python",
      "args": ["/home/macryba/mcp-server/server.py"],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "gnosis": {
      "type": "stdio",
      "command": "/home/macryba/.local/bin/gnosis-mcp",
      "args": ["serve", "--watch", "history-data/"],
      "env": {
        "GNOSIS_MCP_DATABASE_URL": ".gnosis-data/gnosis.db",
        "GNOSIS_MCP_EMBED_PROVIDER": "local",
        "GNOSIS_MCP_WRITABLE": "true"
      }
    }
  }
}
